RewriteEngine On

# Force HTTPS + WWW
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.rehabverve\.com\.ng$ [NC]
RewriteRule ^ https://www.rehabverve.com.ng%{REQUEST_URI} [L,R=301]

# Allow clean URLs WITHOUT breaking .html usage
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Custom routes (optional)
RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog-single.html?slug=$1 [L,QSA]